<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".views.gym.GymView">


    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_theme_primary"
        android:fitsSystemWindows="true"
        app:elevation="0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarAdd"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@color/white"
            app:popupTheme="@style/ThemeOverlay.Material3.MaterialAlertDialog"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/GymTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/hint_placemarkGym"
            android:background="@android:drawable/edit_text"
            android:layout_margin="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/Description"
            android:background="@android:drawable/edit_text"
            android:layout_margin="16dp"
            app:layout_constraintTop_toBottomOf="@id/GymTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/ratingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/gymrating"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/description"
            app:layout_constraintStart_toStartOf="parent"/>

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:numStars="5"
            android:progressTint="@android:color/holo_orange_light"
            android:secondaryProgressTint="@android:color/holo_orange_light"
            android:backgroundTint="@android:color/transparent"
            android:stepSize="0.5"
            app:layout_constraintBottom_toBottomOf="@id/ratingLabel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ratingLabel" />

        <TextView
            android:id="@+id/ratingLabel2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/ratingBar"
            app:layout_constraintStart_toStartOf="parent"/>

        <Spinner
            android:id="@+id/countySpinner"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="@id/ratingLabel2"
            app:layout_constraintBottom_toBottomOf="@id/ratingLabel2"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/chooseImage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/button_addImage"
            android:layout_margin="8dp"
            app:layout_constraintTop_toBottomOf="@id/countySpinner"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/gymLocation"/>

        <Button
            android:id="@+id/gymLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/button_location"
            android:layout_margin="8dp"
            app:layout_constraintTop_toBottomOf="@id/countySpinner"
            app:layout_constraintStart_toEndOf="@id/chooseImage"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/gymImage"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_margin="8dp"
            android:scaleType="centerCrop"
            android:contentDescription="@string/gym_image"
            app:layout_constraintTop_toBottomOf="@id/chooseImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/m3_split_button_chevron_avd"/>

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/button_addGym"
            android:backgroundTint="@color/md_theme_primary"
            android:textColor="@color/white"
            android:layout_margin="8dp"
            app:layout_constraintTop_toBottomOf="@id/gymImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/DeleteGym"/>

        <Button
            android:id="@+id/DeleteGym"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/delete"
            android:textColor="@color/white"
            android:layout_margin="8dp"
            app:layout_constraintTop_toBottomOf="@id/gymImage"
            app:layout_constraintStart_toEndOf="@id/btnAdd"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>